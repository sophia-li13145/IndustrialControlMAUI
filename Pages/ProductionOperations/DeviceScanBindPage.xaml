<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IndustrialControlMAUI.Pages.DeviceScanBindPage"
             Title="设备扫描绑定">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="10">
            <Label Text="工单基础信息" FontAttributes="Bold" FontSize="18" />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                <Label Text="工单编号：" Grid.Row="0" />
                <Label Text="{Binding WorkOrderNo}" Grid.Row="0" Grid.Column="1" />
                <Label Text="工单名称：" Grid.Row="1" />
                <Label Text="{Binding WorkOrderName}" Grid.Row="1" Grid.Column="1" />
                <Label Text="产品名称：" Grid.Row="2" />
                <Label Text="{Binding MaterialName}" Grid.Row="2" Grid.Column="1" />
                <Label Text="生产数量：" Grid.Row="3" />
                <Label Text="{Binding ScheQty}" Grid.Row="3" Grid.Column="1" />
                <Label Text="工序：" Grid.Row="4" />
                <Label Text="{Binding ProcessName}" Grid.Row="4" Grid.Column="1" FontAttributes="Bold" />
            </Grid>

            <Label Text="添加关联设备" FontAttributes="Bold" FontSize="18" />
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                <Label Text="设备编号" VerticalOptions="Center" />
                <Entry x:Name="DeviceCodeEntry" Grid.Column="1" Placeholder="请输入/扫码" Text="{Binding DeviceCodeInput}" />
                <ImageButton Grid.Column="2"
                             Source="scan_button.png"
                             WidthRequest="36"
                             HeightRequest="36"
                             BackgroundColor="Transparent"
                             Clicked="OnScanDeviceClicked" />

                <Button Grid.Row="1" Grid.ColumnSpan="3" Text="扫码绑定" Command="{Binding BindScanDeviceCommand}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Picker Grid.Column="0"
                        ItemsSource="{Binding DeviceOptions}"
                        ItemDisplayBinding="{Binding Text}"
                        SelectedItem="{Binding SelectedDeviceOption}" />
                <Button Grid.Column="1" Text="手动绑定" Clicked="OnManualBindClicked" />
            </Grid>

            <Grid ColumnDefinitions="Auto,Auto,Auto,*" Padding="6" BackgroundColor="#F1F1F1">
                <Label Text="设备名称" FontAttributes="Bold" WidthRequest="120" />
                <Label Grid.Column="1" Text="开始时间" FontAttributes="Bold" WidthRequest="130" />
                <Label Grid.Column="2" Text="结束时间" FontAttributes="Bold" WidthRequest="130" />
            </Grid>

            <CollectionView ItemsSource="{Binding BoundDevices}" EmptyView="暂无绑定设备">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" Padding="6" ColumnSpacing="6">
                            <Label Text="{Binding deviceName}" WidthRequest="120" />
                            <Label Grid.Column="1" Text="{Binding startTime}" WidthRequest="130" />
                            <Label Grid.Column="2" Text="{Binding endTime}" WidthRequest="130" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
