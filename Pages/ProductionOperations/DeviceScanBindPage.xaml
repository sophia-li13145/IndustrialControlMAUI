<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IndustrialControlMAUI.Pages.DeviceScanBindPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#D9DEE5">

    <Grid RowDefinitions="58,*">

        <!-- 顶部蓝条 -->
        <Grid Grid.Row="0"
              BackgroundColor="#0B7BEE"
              Padding="12,0">
            <Label Text="生产管理系统"
                   VerticalOptions="Center"
                   HorizontalOptions="Start"
                   TextColor="White"
                   FontSize="16"
                   FontAttributes="Bold" />
        </Grid>

        <!-- 页面主体 -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="10,10,10,20"
                                 Spacing="10">

                <!-- 工单基础信息标题 -->
                <HorizontalStackLayout Spacing="4">
                    <BoxView WidthRequest="4"
                             HeightRequest="20"
                             Color="#1E7AF0"
                             VerticalOptions="Center" />
                    <Label Text="工单基础信息"
                           FontSize="15"
                           TextColor="#4A4A4A"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- 工单基础信息 -->
                <Border Stroke="#B6BBC5"
                        BackgroundColor="White"
                        Padding="0">
                    <Grid RowDefinitions="Auto,Auto,Auto"
                          ColumnDefinitions="*,*"
                          RowSpacing="0"
                          ColumnSpacing="0">

                        <!-- 第一行：工单编号 -->
                        <Grid Padding="8,10"
                              BackgroundColor="White">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Text="工单编号："
                                   TextColor="#333333"
                                   VerticalOptions="Start"
                                   LineBreakMode="NoWrap" />

                            <Label Grid.Column="1"
                                   Text="{Binding WorkOrderNo}"
                                   TextColor="#333333"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2"
                                   VerticalOptions="Start" />
                        </Grid>

                        <!-- 第一行：产品名称 -->
                        <Grid Grid.Column="1"
                              Padding="8,10"
                              BackgroundColor="White">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Text="产品名称："
                                   TextColor="#333333"
                                   VerticalOptions="Start"
                                   LineBreakMode="NoWrap" />

                            <Label Grid.Column="1"
                                   Text="{Binding MaterialName}"
                                   TextColor="#333333"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2"
                                   VerticalOptions="Start" />
                        </Grid>

                        <!-- 第二行：工单名称 -->
                        <Grid Grid.Row="1"
                              Padding="8,10"
                              BackgroundColor="White">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Text="工单名称："
                                   TextColor="#333333"
                                   VerticalOptions="Start"
                                   LineBreakMode="NoWrap" />

                            <Label Grid.Column="1"
                                   Text="{Binding WorkOrderName}"
                                   TextColor="#333333"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2"
                                   VerticalOptions="Start" />
                        </Grid>

                        <!-- 第二行：生产数量 -->
                        <Grid Grid.Row="1"
                              Grid.Column="1"
                              Padding="8,10"
                              BackgroundColor="White">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label Text="生产数量："
                                   TextColor="#333333"
                                   VerticalOptions="Center"
                                   LineBreakMode="NoWrap" />

                            <Label Grid.Column="1"
                                   Text="{Binding ScheQty}"
                                   TextColor="#333333"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- 中间竖线 -->
                        <BoxView Grid.RowSpan="2"
                                 Grid.Column="1"
                                 WidthRequest="1"
                                 BackgroundColor="#B6BBC5"
                                 HorizontalOptions="Start" />

                        <!-- 第一行横线 -->
                        <BoxView Grid.ColumnSpan="2"
                                 HeightRequest="1"
                                 BackgroundColor="#B6BBC5"
                                 VerticalOptions="End" />

                        <!-- 第二行横线 -->
                        <BoxView Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 HeightRequest="1"
                                 BackgroundColor="#B6BBC5"
                                 VerticalOptions="End" />

                        <!-- 第三行：工序 -->
                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="2"
                              Padding="8,10"
                              BackgroundColor="White">
                            <HorizontalStackLayout HorizontalOptions="Center"
                                                   Spacing="6">
                                <Label Text="工序:"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#111111" />
                                <Label Text="{Binding ProcessName}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#111111" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 添加关联设备标题 -->
                <HorizontalStackLayout Margin="0,6,0,0"
                                       Spacing="4">
                    <BoxView WidthRequest="4"
                             HeightRequest="20"
                             Color="#1E7AF0"
                             VerticalOptions="Center" />
                    <Label Text="添加关联设备"
                           FontSize="15"
                           TextColor="#4A4A4A"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- 设备区域 -->
                <Border Stroke="#B8B8B8"
                        StrokeThickness="1"
                        BackgroundColor="#F7F7F7"
                        Padding="8">
                    <VerticalStackLayout Spacing="8">

                        <!-- 输入行 -->
                        <Grid ColumnDefinitions="72,*,52"
                              ColumnSpacing="8"
                              VerticalOptions="Center">
                            <Label Text="设备编号"
                                   FontSize="15"
                                   TextColor="#333333"
                                   VerticalTextAlignment="Center"
                                   HeightRequest="40" />

                            <Border Grid.Column="1"
                                    Stroke="#B8B8B8"
                                    StrokeThickness="1"
                                    BackgroundColor="White"
                                    HeightRequest="40"
                                    Padding="8,0">
                                <Entry x:Name="DeviceCodeEntry"
                                       Text="{Binding DeviceCodeInput}"
                                       Placeholder="请输入"
                                       FontSize="14"
                                       TextColor="#333333"
                                       BackgroundColor="Transparent"
                                       ClearButtonVisibility="WhileEditing"
                                       VerticalOptions="Center"
                                       Completed="OnDeviceCodeCompleted" />
                            </Border>

                            <Border Grid.Column="2"
                                    Stroke="#B8B8B8"
                                    StrokeThickness="1"
                                    BackgroundColor="White"
                                    HeightRequest="40"
                                    WidthRequest="48"
                                    Padding="0">
                                <ImageButton Source="scan_button.png"
                                             BackgroundColor="Transparent"
                                             Clicked="OnScanDeviceClicked"
                                             Aspect="AspectFit"
                                             Padding="6" />
                            </Border>
                        </Grid>

                        <!-- 手动绑定按钮 -->
                        <Button Text="＋ 手动绑定"
                                Clicked="OnManualBindClicked"
                                HorizontalOptions="Start"
                                BackgroundColor="Transparent"
                                BorderColor="#2D73FF"
                                BorderWidth="1"
                                CornerRadius="2"
                                Padding="10,4"
                                FontSize="14"
                                TextColor="#2D73FF" />

                        <!-- 关联设备标题 -->
                        <Label Text="工单关联设备："
       FontSize="16"
       FontAttributes="Bold"
       TextColor="#222222"
       Margin="0,2,0,6" />

                        <!-- 表格整体 -->
                        <VerticalStackLayout Spacing="0">

                            <!-- 表头 -->
                            <Grid ColumnDefinitions="*,*,*,120"
      ColumnSpacing="0"
      RowSpacing="0">

                                <Border Stroke="#B8B8B8"
            StrokeThickness="1"
            BackgroundColor="#F3F3F3"
            Padding="4,8"
            MinimumHeightRequest="36">
                                    <Label Text="设备名称"
               FontSize="14"
               TextColor="#333333"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               VerticalOptions="Center" />
                                </Border>

                                <Border Grid.Column="1"
            Stroke="#B8B8B8"
            StrokeThickness="1"
            BackgroundColor="#F3F3F3"
            Padding="4,8"
            MinimumHeightRequest="36">
                                    <Label Text="开始时间"
               FontSize="14"
               TextColor="#333333"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               VerticalOptions="Center" />
                                </Border>

                                <Border Grid.Column="2"
            Stroke="#B8B8B8"
            StrokeThickness="1"
            BackgroundColor="#F3F3F3"
            Padding="4,8"
            MinimumHeightRequest="36">
                                    <Label Text="结束时间"
               FontSize="14"
               TextColor="#333333"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               VerticalOptions="Center" />
                                </Border>

                                <Border Grid.Column="3"
            Stroke="#B8B8B8"
            StrokeThickness="1"
            BackgroundColor="#F3F3F3"
            Padding="4,8"
            MinimumHeightRequest="36">
                                    <Label Text="操作"
               FontSize="14"
               TextColor="#333333"
               HorizontalTextAlignment="Center"
               VerticalTextAlignment="Center"
               VerticalOptions="Center" />
                                </Border>
                            </Grid>

                            <!-- 数据列表 -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding BoundDevices}"
                         Spacing="0"
                         Margin="0">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                            <Grid ColumnDefinitions="*,*,*,120"
              ColumnSpacing="0"
              RowSpacing="0">

                                            <Border Stroke="#B8B8B8"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    Padding="4,8"
                    MinimumHeightRequest="42">
                                                <Label Text="{Binding deviceName}"
                       FontSize="14"
                       TextColor="#333333"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       VerticalOptions="Center"
                       LineBreakMode="WordWrap"
                       MaxLines="2" />
                                            </Border>

                                            <Border Grid.Column="1"
                    Stroke="#B8B8B8"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    Padding="4,8"
                    MinimumHeightRequest="42">
                                                <Label Text="{Binding startTime}"
                       FontSize="14"
                       TextColor="#333333"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       VerticalOptions="Center"
                       LineBreakMode="WordWrap"
                       MaxLines="2" />
                                            </Border>

                                            <Border Grid.Column="2"
                    Stroke="#B8B8B8"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    Padding="4,8"
                    MinimumHeightRequest="42">
                                                <Label Text="{Binding endTime}"
                       FontSize="14"
                       TextColor="#333333"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       VerticalOptions="Center"
                       LineBreakMode="WordWrap"
                       MaxLines="2" />
                                            </Border>

                                            <Border Grid.Column="3"
                    Stroke="#B8B8B8"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    Padding="4,8"
                    MinimumHeightRequest="42">
                                                <HorizontalStackLayout HorizontalOptions="Center"
                                                                       VerticalOptions="Center"
                                                                       Spacing="12">
                                                    <Button Text="编辑"
                                                            FontSize="13"
                                                            TextColor="#2D73FF"
                                                            BackgroundColor="#EEF5FF"
                                                            BorderColor="#2D73FF"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            Padding="8,2"
                                                            Clicked="OnEditBoundDeviceClicked"
                                                            CommandParameter="{Binding .}" />

                                                    <Button Text="删除"
                                                            FontSize="13"
                                                            TextColor="#FF4D4F"
                                                            BackgroundColor="#FFF1F0"
                                                            BorderColor="#FF4D4F"
                                                            BorderWidth="1"
                                                            CornerRadius="4"
                                                            Padding="8,2"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteBoundDeviceCommand}"
                                                            CommandParameter="{Binding .}" />
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                        <!-- 空数据提示 -->
                        <Label Text="暂无绑定设备"
                               TextColor="#999999"
                               HorizontalOptions="Center"
                               IsVisible="{Binding BoundDevices.Count, Converter={StaticResource ZeroToBoolConverter}}" />

                        <BoxView HeightRequest="20"
                                 Color="Transparent" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 工单上下文加载遮罩 -->
        <Grid Grid.RowSpan="2"
              IsVisible="{Binding IsContextLoading}"
              BackgroundColor="#66000000"
              InputTransparent="False">
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="20,16"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="12"
                                       VerticalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsContextLoading}"
                                       Color="#0B7BEE"
                                       WidthRequest="26"
                                       HeightRequest="26" />
                    <Label Text="工单信息加载中..."
                           TextColor="#333333"
                           VerticalTextAlignment="Center"
                           FontSize="14" />
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
