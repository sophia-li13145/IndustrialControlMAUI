<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="IndustrialControlMAUI.Pages.ManualDeviceBindPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Size="340,240">

    <Border BackgroundColor="White" Stroke="#DDDDDD" StrokeShape="RoundRectangle 10" Padding="16">
        <VerticalStackLayout Spacing="12">
            <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label Text="设备名称" VerticalOptions="Center" />

                <Picker Grid.Column="1"
                        IsVisible="{Binding AllowDeviceSelection}"
                        ItemsSource="{Binding DeviceOptions}"
                        ItemDisplayBinding="{Binding Text}"
                        SelectedItem="{Binding SelectedDeviceOption, Mode=TwoWay}" />

                <Border Grid.Column="1"
                        IsVisible="{Binding IsReadonlyDeviceVisible}"
                        Stroke="#D1D5DB"
                        StrokeThickness="1"
                        BackgroundColor="#F3F4F6"
                        Padding="10,8">
                    <Label Text="{Binding SelectedDeviceName}"
                           TextColor="#374151"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Label Text="操作时间" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="{Binding OperateTimeText}" VerticalOptions="Center" />
            </Grid>

            <HorizontalStackLayout HorizontalOptions="End" Spacing="12">
                <Button Text="取消" Clicked="OnCancelClicked" />
                <Button Text="确认" Clicked="OnConfirmClicked" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
