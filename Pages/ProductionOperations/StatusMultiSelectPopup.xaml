<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="IndustrialControlMAUI.Pages.StatusMultiSelectPopup"
               CanBeDismissedByTappingOutsideOfPopup="False">
    <Border BackgroundColor="White"
            Stroke="#D0D5DD"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 8"
            Padding="12"
            WidthRequest="220">

        <VerticalStackLayout Spacing="10">
            <Label Text="选择状态"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#333333" />

            <ScrollView HeightRequest="220">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Options}"
                         Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="30,*"
                      Padding="4,8">

                                <Label Grid.Column="0"
                           Text="☐"
                           FontSize="18"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           TextColor="#4F46E5">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                         Binding="{Binding IsSelected}"
                                         Value="True">
                                            <Setter Property="Text" Value="☑" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Label Grid.Column="1"
                           Text="{Binding Text}"
                           VerticalOptions="Center"
                           TextColor="#333333" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnOptionTapped" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>

            <Button Text="确定"
                    HeightRequest="36"
                    Clicked="OnDoneClicked" />
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
