<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="IndustrialControlMAUI.Pages.FlexibleStockCheckPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:IndustrialControlMAUI.Converters"
    xmlns:behaviors="clr-namespace:IndustrialControlMAUI.Behaviors"
    x:Name="Page"
    Title="{Binding PageTitle}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:DecimalTrimConverter x:Key="TrimNumber" />
            <conv:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid>

        <!-- 主体内容 -->
        <ScrollView>
            <VerticalStackLayout Padding="12" Spacing="10">

                <!-- 顶部：库位号 / 物料条码 + 保存 -->
                <Grid ColumnDefinitions="80,*,80"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="6"
                      RowSpacing="6">

                    <!-- 库位号 -->
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="库位号：" VerticalTextAlignment="Center" />
                    <Entry x:Name="LocationEntry"
                           Grid.Row="0" Grid.Column="1"
                           Placeholder="请扫描/输入库位"
                           Text="{Binding LocationCode}"
                           Completed="OnLocationCompleted" />
                    <ImageButton Grid.Row="0" Grid.Column="2"
                                  Source="scan_button.png"      
                                 WidthRequest="36"
                                  HeightRequest="36"
                                 BackgroundColor="Transparent"
                                 Aspect="AspectFit"
                                 Clicked="OnLocationScanClicked" />

                    <!-- 物料条码 -->
                    <Label Grid.Row="1" Grid.Column="0"
                           Text="物料条码：" VerticalTextAlignment="Center" />
                    <Entry x:Name="MaterialEntry"
                           Grid.Row="1" Grid.Column="1"
                           Placeholder="请扫描/输入物料条码"
                           Text="{Binding MaterialBarcode}"
                           Completed="OnMaterialCompleted" />
                    <ImageButton Grid.Row="1" Grid.Column="2"
                                  Source="scan_button.png"      
                                     WidthRequest="36"
                                      HeightRequest="36"
                                 BackgroundColor="Transparent"
                                 Aspect="AspectFit"
                                 Clicked="OnMaterialScanClicked" />
                    <Label Grid.Row="2" Grid.Column="0"
                           Text="料框条码：" VerticalTextAlignment="Center" TextColor="#2C6BED"/>
                    <Entry Grid.Row="2" Grid.Column="1"
                           Placeholder="请扫描/输入料框编号"
                           Text="{Binding FrameNo}" />
                    <ImageButton Grid.Row="2" Grid.Column="2"
                                 Source="scan_button.png"
                                 WidthRequest="36"
                                 HeightRequest="36"
                                 BackgroundColor="Transparent"
                                 Aspect="AspectFit" />
                    <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                          ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="保存"
                                BackgroundColor="#1976D2"
                                TextColor="White"
                                CornerRadius="6"
                                HeightRequest="40"
                                IsVisible="{Binding IsSaveButtonVisible}"
                                IsEnabled="{Binding CanEdit}"
                                Command="{Binding SaveCommand}" />
                        <Button Grid.Column="1"
                                Text="结存"
                                BackgroundColor="{Binding SettleButtonBackgroundColor}"
                                TextColor="White"
                                CornerRadius="6"
                                HeightRequest="40"
                                IsVisible="{Binding IsSettleButtonVisible}"
                                IsEnabled="{Binding IsSettleButtonEnabled}"
                                Command="{Binding SettleCommand}" />
                    </Grid>

                </Grid>

                <!-- 盘点单号 + 仓库名称（同一行显示） -->
                <Frame Padding="8,6"
                   HasShadow="False"
                   Margin="0,4,0,0"
                   CornerRadius="4"
                   BorderColor="#E0E0E0"
                   BackgroundColor="White">
                    <Grid ColumnDefinitions="Auto,*,Auto,*"
                      RowDefinitions="Auto"
                      ColumnSpacing="4">

                        <Label Grid.Column="0"
                           Text="盘点单号："
                           IsVisible="{Binding IsFlexibleMode, Converter={StaticResource InverseBool}}" />
                        <Label Grid.Column="1"
                           Text="{Binding CheckNo}"
                           IsVisible="{Binding IsFlexibleMode, Converter={StaticResource InverseBool}}" />

                        <!-- 普通盘点：仓库名称放在右侧（列2/3） -->
                        <Label Grid.Column="2"
                           Text="仓库名称："
                           IsVisible="{Binding IsFlexibleMode, Converter={StaticResource InverseBool}}" />
                        <Label Grid.Column="3"
                           Text="{Binding WarehouseName}"
                           IsVisible="{Binding IsFlexibleMode, Converter={StaticResource InverseBool}}" />

                        <!-- 灵活盘点：仓库名称放在左侧第二列（列0/1） -->
                        <Label Grid.Column="0"
                           Text="仓库名称："
                           IsVisible="{Binding IsFlexibleMode}" />
                        <Label Grid.Column="1"
                           Text="{Binding WarehouseName}"
                           IsVisible="{Binding IsFlexibleMode}" />
                    </Grid>
                </Frame>

                <Label Text="盘点明细"
                       FontAttributes="Bold"
                       Margin="0,4,0,0" />

                <!-- 明细列表 -->
                <CollectionView ItemsSource="{Binding Details}"
                                SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="0"
                               Margin="0,4"
                               HasShadow="False"
                               BorderColor="#E0E0E0"
                               CornerRadius="4"
                               BackgroundColor="White">

                                <Frame.Triggers>

                                    <!-- 点击选中时变绿 -->
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding IsSelected}"
                                                 Value="True">  
                                        <Setter Property="BackgroundColor" Value="#A5FF9E" />
                                    </DataTrigger>
                                </Frame.Triggers>


                                <!-- 点击整条记录打开弹窗 -->
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.OpenEditDialogCommand, Source={x:Reference Page}}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>

                                <Grid ColumnDefinitions="30,*"
                                      RowSpacing="2">

                                    <!-- 左边序号 -->
                                    <Label Grid.RowSpan="6"
                                           Grid.Column="0"
                                           Text="{Binding index}"
                                           HorizontalTextAlignment="Center"
                                            />

                                    <!-- 右边内容 -->
                                    <Grid Grid.Column="1"
                                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                          ColumnDefinitions="90,*,90,*"
                                          RowSpacing="2" ColumnSpacing="2">

                                        <!-- 行1：库位号 / 批次号 -->
                                        <Label Grid.Row="0" Grid.Column="0" Text="库位号：" />
                                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding location}" />
                                        <Label Grid.Row="0" Grid.Column="2" Text="批次号：" />
                                        <Label Grid.Row="0" Grid.Column="3" Text="{Binding stockBatch}" />

                                        <!-- 行2：物料编码 / 物料名称 -->
                                        <Label Grid.Row="1" Grid.Column="0" Text="物料编码：" />
                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding materialCode}" />
                                        <Label Grid.Row="1" Grid.Column="2" Text="物料名称：" />
                                        <Label Grid.Row="1" Grid.Column="3" Text="{Binding materialName}" />

                                        <!-- 行3：包含料框 / 总账存 -->
                                        <Label Grid.Row="2" Grid.Column="0" Text="包含料框：" />
                                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding FrameCount, StringFormat='{}{0} 个'}" />
                                        <Label Grid.Row="2" Grid.Column="2" Text="总账存：" />
                                        <Label Grid.Row="2" Grid.Column="3" Text="{Binding instockQty, Converter={StaticResource TrimNumber}}" />

                                        <!-- 行4：总盘点 / 总盈亏 -->
                                        <Label Grid.Row="3" Grid.Column="0" Text="总盘点：" />
                                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding checkQty, Converter={StaticResource TrimNumber}}" />
                                        <Label Grid.Row="3" Grid.Column="2" Text="总盈亏：" />
                                        <Label Grid.Row="3" Grid.Column="3" Text="{Binding profitLossQty, Converter={StaticResource TrimNumber}}" />

                                        <!-- 行5：批次备注 -->
                                        <Label Grid.Row="4" Grid.Column="0" Text="批次备注：" />
                                        <Label Grid.Row="4" Grid.Column="1"
                                               Grid.ColumnSpan="3"
                                               Text="{Binding memo}" />
                                    </Grid>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== 弹窗 Overlay ===== -->
        <Grid IsVisible="{Binding IsEditDialogVisible}"
              BackgroundColor="#66000000"
              RowDefinitions="*,Auto">
            <BoxView Grid.Row="0" Color="Transparent" />
            <Frame Grid.Row="1"
                   Padding="0"
                   CornerRadius="10"
                   HasShadow="False"
                   BackgroundColor="#F4F7FC"
                   HorizontalOptions="Fill"
                   VerticalOptions="End"
                   Margin="0">

                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto"
                      ColumnDefinitions="90,*"
                      RowSpacing="6"
                      ColumnSpacing="4"
                      Padding="10,8,10,8">

                    <!-- 标题行：库位号 + 批次号 + 关闭按钮 -->
                    <Grid Grid.Row="0" Grid.ColumnSpan="2"
                          ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding EditingItem.location, StringFormat='库位号：{0}'}"
                               FontAttributes="Bold" />
                        <Label Grid.Column="1"
                               Text="✕"
                               TextColor="Red"
                               FontSize="18"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding CancelEditCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <Label Grid.Row="1" Grid.Column="0" Text="物料名称：" />
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding EditingItem.materialName}" />

                    <Label Grid.Row="2" Grid.Column="0" Text="物料编码：" />
                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding EditingItem.materialCode}" />

                    <Label Grid.Row="3" Grid.Column="0" Text="批次号：" />
                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding EditingItem.stockBatch}" />

                    <Label Grid.Row="4" Grid.Column="0" Text="账存数量：" />
                    <HorizontalStackLayout Grid.Row="4" Grid.Column="1" Spacing="4">
                        <Label Text="{Binding EditingItem.instockQty, Converter={StaticResource TrimNumber}}" />
                        <Label Text="{Binding EditingItem.unit}" />
                    </HorizontalStackLayout>

                    <Label Grid.Row="5" Grid.Column="0" Text="总盘点数量：" TextColor="#2C6BED" FontAttributes="Bold" />
                    <Entry Grid.Row="5" Grid.Column="1"
                            x:Name="CheckQtyEntry"
                           Placeholder="请输入"
                           Text="{Binding EditCheckQtyText, Mode=TwoWay}"
                           Keyboard="Numeric">
                        <Entry.Behaviors>
                            <behaviors:ClearOnFocusBehavior />
                        </Entry.Behaviors>
                    </Entry>
                    <VerticalStackLayout Grid.Row="6" Grid.ColumnSpan="2" Spacing="6">
                        <Label Text="料框明细维护" FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*,42,56" RowDefinitions="Auto" ColumnSpacing="4">
                            <Entry Grid.Column="0" Placeholder="扫码/输入新增料框" Text="{Binding EditFrameNoInput}" />
                            <ImageButton Grid.Column="1"
                                         Source="scan_button.png"
                                         WidthRequest="28"
                                         HeightRequest="28"
                                         Padding="0"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         BackgroundColor="Transparent" />
                            <Button Grid.Column="2"
                                    Text="添加"
                                    HeightRequest="32"
                                    Padding="0"
                                    VerticalOptions="Center"
                                    Command="{Binding AddFrameToEditingCommand}"
                                    BackgroundColor="#22C55E"
                                    TextColor="White" />
                        </Grid>
                        <CollectionView ItemsSource="{Binding EditingItem.wmsInstockCheckFrameDetailList}"
                                        VerticalOptions="FillAndExpand">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Padding="6" Margin="0,2" BorderColor="#D1D5DB" HasShadow="False">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame" Binding="{Binding IsScannedMatch}" Value="True">
                                                <Setter Property="BorderColor" Value="#2563EB"/>
                                                <Setter Property="BackgroundColor" Value="#DBEAFE"/>
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding frameNo, StringFormat='□ {0}'}" FontAttributes="Bold"/>
                                            <Label Grid.Column="1" Text="{Binding bookQty, StringFormat='账存 {0}'}"/>
                                            <Entry Grid.Row="1" Placeholder="盘点数量" Keyboard="Numeric" Text="{Binding CheckQtyText}" />
                                            <Entry Grid.Row="1" Grid.Column="1" Placeholder="备注" Text="{Binding EditMemo}" />
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- 按钮行 -->
                    <Grid Grid.Row="7" Grid.ColumnSpan="2"
                          Margin="0,8,0,0"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="0">
                        <Button Grid.Column="0"
                                Text="取消"
                                BackgroundColor="White"
                                BorderColor="#D1D5DB"
                                BorderWidth="1"
                                TextColor="#111827"
                                CornerRadius="0"
                                Command="{Binding CancelEditCommand}" />
                        <Button Grid.Column="1"
                                Text="确认保存"
                                BackgroundColor="#3B82F6"
                                TextColor="White"
                                CornerRadius="0"
                                Command="{Binding ConfirmEditCommand}" />
                    </Grid>
                </Grid>
            </Frame>
        </Grid>
        <!-- ===== 全局 Loading 蒙层（纯圆圈） ===== -->
        <Grid IsVisible="{Binding IsBusy}"
          BackgroundColor="#80000000"
          InputTransparent="False">

            <ActivityIndicator IsRunning="True"
                           IsVisible="True"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="60"
                           HeightRequest="60" />
        </Grid>
    </Grid>
</ContentPage>
