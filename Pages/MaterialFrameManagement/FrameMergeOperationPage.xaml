<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.FrameMergeOperationPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding PageTitle}"
             BackgroundColor="#F4F5F7">
    <Grid Padding="12" RowDefinitions="*,Auto">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Items}" RemainingItemsThreshold="2" RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,10" Padding="14" CornerRadius="12" HasShadow="False" BorderColor="#E5E7EB" BackgroundColor="White">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnItemTapped" CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding BizNoDisplay}" FontAttributes="Bold" FontSize="24" TextColor="#111827"/>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="目标框:" TextColor="#6B7280"/>
                                <Label Grid.Column="1" Text="{Binding targetLocation}" TextColor="#111827"/>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="来源:" TextColor="#6B7280"/>
                                <Label Grid.Column="1" Text="{Binding FrameCountDisplay, StringFormat='合并了 {0} 个原料框'}" TextColor="#111827"/>
                            </Grid>

                            <BoxView HeightRequest="1" BackgroundColor="#E5E7EB"/>
                            <Label Text="{Binding OperationTimeDisplay}" TextColor="#9CA3AF"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView><Label Text="暂无数据" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#9CA3AF"/></CollectionView.EmptyView>
        </CollectionView>
        <Button Grid.Row="1" Text="新增记录" HeightRequest="44" CornerRadius="10" TextColor="White" BackgroundColor="#2F66E8" Clicked="OnAddRecordClicked"/>
    </Grid>
</ContentPage>
