<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.FrameEmptyAddPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="新增空框"
             BackgroundColor="#F4F5F7">
    <Grid Padding="12" RowDefinitions="Auto,*,Auto">
        <Frame CornerRadius="12" BackgroundColor="White" BorderColor="#E5E7EB" HasShadow="False" Padding="12">
            <VerticalStackLayout Spacing="12">
                <Label Text="释放料框" FontAttributes="Bold" FontSize="24"/>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Text="扫码添加" Clicked="OnScanClicked" BackgroundColor="#FEF2F2" TextColor="#EF4444"/>
                    <Button Grid.Column="1" Text="列表选择" Command="{Binding OpenPickerCommand}" BackgroundColor="#EEF2FF" TextColor="#374151"/>
                </Grid>

                <CollectionView ItemsSource="{Binding SelectedFrames}">
                    <CollectionView.EmptyView>
                        <Border HeightRequest="230" Stroke="#D1D5DB" StrokeShape="RoundRectangle 10" BackgroundColor="#F9FAFB">
                            <Label Text="暂无选择料框" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#9CA3AF"/>
                        </Border>
                    </CollectionView.EmptyView>
                    <CollectionView.Header>
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding CanConfirm}">
                            <Label Text="{Binding SelectedCountText, StringFormat='已选择待释放料框: {0} 个'}" TextColor="#6B7280"/>
                            <Label Grid.Column="1" Text="清空" TextColor="#9CA3AF">
                                <Label.GestureRecognizers><TapGestureRecognizer Command="{Binding ClearAllCommand}"/></Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate><DataTemplate><Frame Margin="0,4" Padding="10" BorderColor="#E5E7EB" BackgroundColor="#F9FAFB" HasShadow="False" CornerRadius="10"><Grid ColumnDefinitions="*,Auto,Auto"><Label Text="{Binding frameNo}" FontAttributes="Bold"/><Label Grid.Column="1" Text="空闲" TextColor="#16A34A" BackgroundColor="#DCFCE7" Padding="8,2"/><Label Grid.Column="2" Text="✕" TextColor="#9CA3AF"><Label.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveSelectedCommand}" CommandParameter="{Binding .}"/></Label.GestureRecognizers></Label></Grid></Frame></DataTemplate></CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Frame>

        <Grid Grid.Row="2" Padding="0,12,0,0">
            <Button Text="{Binding SelectedCountText, StringFormat='确认释放 ({0})'}" Command="{Binding ConfirmCommand}" IsEnabled="{Binding CanConfirm}" BackgroundColor="{Binding ConfirmButtonColor}" TextColor="{Binding ConfirmButtonTextColor}"/>
        </Grid>

        <Grid Grid.RowSpan="3" BackgroundColor="#66000000" IsVisible="{Binding IsPickerVisible}">
            <Frame VerticalOptions="End" CornerRadius="16" BackgroundColor="White" Padding="12">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" MaximumHeightRequest="560">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="选择料框（多选）" FontAttributes="Bold"/>
                        <Button Grid.Column="1" Text="✕" Command="{Binding ClosePickerCommand}"/>
                    </Grid>

                    <CollectionView Grid.Row="1" ItemsSource="{Binding PickerFrameList}" SelectionMode="None" RemainingItemsThreshold="1" RemainingItemsThresholdReachedCommand="{Binding LoadMorePickerFramesCommand}">
                        <CollectionView.ItemTemplate><DataTemplate><Frame Margin="0,6" Padding="10" BorderColor="#D9D9D9" HasShadow="False"><Frame.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TogglePickCommand}" CommandParameter="{Binding .}"/></Frame.GestureRecognizers><Frame.Triggers><DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True"><Setter Property="BorderColor" Value="#2D73FF"/><Setter Property="BackgroundColor" Value="#EEF5FF"/></DataTrigger></Frame.Triggers><Grid ColumnDefinitions="34,*"><Grid WidthRequest="22" HeightRequest="22" VerticalOptions="Center"><Border Stroke="#C0C4CC" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White"/><Border Stroke="#2D73FF" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#2D73FF" IsVisible="{Binding IsSelected}"/><Label Text="✓" TextColor="White" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsSelected}"/></Grid><VerticalStackLayout Grid.Column="1"><Label Text="{Binding frameNo}" FontAttributes="Bold"/><HorizontalStackLayout Spacing="6"><Label Text="状态:" FontSize="12"/><Border StrokeThickness="0" BackgroundColor="#FEE2E2" Padding="6,1"><Label Text="{Binding FrameStatusDisplayText}" FontSize="11" TextColor="#DC2626"/></Border></HorizontalStackLayout></VerticalStackLayout></Grid></Frame></DataTemplate></CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Grid.Row="2" Text="确认选择" Command="{Binding ConfirmPickCommand}" BackgroundColor="#2F66E8" TextColor="White" HeightRequest="44"/>
                </Grid>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
