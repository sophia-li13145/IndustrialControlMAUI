<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.FramePourAddPage" xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" Title="新增倒框" BackgroundColor="#F4F5F7">
<Grid Padding="12" RowDefinitions="Auto,Auto,*,Auto">
<Frame Padding="12"><VerticalStackLayout><Grid ColumnDefinitions="*,Auto"><Label Text="原料框（来源）" FontAttributes="Bold"/><Button Grid.Column="1" Text="手动选择" Command="{Binding OpenSourcePickerCommand}"/></Grid><Frame Margin="0,6,0,0" Padding="8" BorderColor="#FDBA74" BackgroundColor="#FFF7ED" HasShadow="False"><Label Text="{Binding SelectedSource.frameNo}" FontAttributes="Bold"/></Frame></VerticalStackLayout></Frame>
<Frame Grid.Row="1" Padding="12" Margin="0,12,0,0"><VerticalStackLayout><Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"><Label Text="目标倒框（去向）" FontAttributes="Bold"/><Button Grid.Column="1" Text="手动选择" Command="{Binding OpenTargetPickerCommand}"/><Button Grid.Column="2" Text="扫码添加" Clicked="OnScanTargetClicked"/></Grid><Frame Margin="0,6,0,0" Padding="8" BorderColor="#86EFAC" BackgroundColor="#F0FDF4" HasShadow="False"><Label Text="{Binding SelectedTarget.frameNo}" FontAttributes="Bold"/></Frame></VerticalStackLayout></Frame>
<Grid Grid.Row="2"/><Button Grid.Row="3" Text="确认一键倒框" Command="{Binding ConfirmCommand}" IsEnabled="{Binding CanConfirm}"/>
<Grid Grid.RowSpan="4" IsVisible="{Binding IsSourcePickerVisible}" BackgroundColor="#66000000"><Frame VerticalOptions="End"><VerticalStackLayout><Label Text="选择原料框（单选）" FontAttributes="Bold"/><CollectionView ItemsSource="{Binding SourceFrameList}" SelectionMode="None"><CollectionView.ItemTemplate><DataTemplate><Frame Margin="0,6" Padding="10" BorderColor="#D9D9D9" HasShadow="False"><Frame.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PickSourceCommand}" CommandParameter="{Binding .}"/></Frame.GestureRecognizers><Label Text="{Binding frameNo}" FontAttributes="Bold"/></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView><Button Text="确认选择" Command="{Binding ConfirmSourceCommand}"/></VerticalStackLayout></Frame></Grid>
<Grid Grid.RowSpan="4" IsVisible="{Binding IsTargetPickerVisible}" BackgroundColor="#66000000"><Frame VerticalOptions="End"><VerticalStackLayout><Label Text="选择目标倒框（空闲,单选）" FontAttributes="Bold"/><CollectionView ItemsSource="{Binding TargetFrameList}" SelectionMode="None"><CollectionView.ItemTemplate><DataTemplate><Frame Margin="0,6" Padding="10" BorderColor="#D9D9D9" HasShadow="False"><Frame.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PickTargetCommand}" CommandParameter="{Binding .}"/></Frame.GestureRecognizers><Label Text="{Binding frameNo}" FontAttributes="Bold"/></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView><Button Text="确认选择" Command="{Binding ConfirmTargetCommand}"/></VerticalStackLayout></Frame></Grid>
</Grid></ContentPage>
