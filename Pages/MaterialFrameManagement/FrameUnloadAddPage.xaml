<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.FrameUnloadAddPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="新增拆框"
             BackgroundColor="#F4F5F7">
    <Grid Padding="12" RowDefinitions="Auto,Auto,*,Auto">
        <Frame CornerRadius="12" BackgroundColor="White" BorderColor="#E5E7EB" HasShadow="False" Padding="16">
            <VerticalStackLayout Spacing="12">
                <HorizontalStackLayout Spacing="6"><Label Text="⬡" FontSize="14" TextColor="#2D73FF"/><Label Text="原料框（来源）" FontSize="14" FontAttributes="Bold" TextColor="#1F2937"/></HorizontalStackLayout>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding ShowSourcePickerActions}">
                    <Border HeightRequest="84" Stroke="#CBD5E1" StrokeThickness="1.5" StrokeDashArray="6,4" StrokeShape="RoundRectangle 10" BackgroundColor="#FAFCFF"><Border.GestureRecognizers><TapGestureRecognizer Command="{Binding OpenSourcePickerCommand}"/></Border.GestureRecognizers><VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6"><Label Text="☰" Rotation="90" FontSize="22" TextColor="#6B7280" HorizontalOptions="Center"/><Label Text="手动选择" FontSize="14" TextColor="#6B7280" HorizontalOptions="Center"/></VerticalStackLayout></Border>
                    <Border Grid.Column="1" HeightRequest="84" Stroke="#93C5FD" StrokeThickness="1.5" StrokeDashArray="6,4" StrokeShape="RoundRectangle 10" BackgroundColor="#EFF6FF"><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnScanSourceClicked"/></Border.GestureRecognizers><VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6"><Label Text="⌗" FontSize="26" TextColor="#2D73FF" HorizontalOptions="Center"/><Label Text="扫码识别" FontSize="14" TextColor="#2D73FF" HorizontalOptions="Center"/></VerticalStackLayout></Border>
                </Grid>
                <Border IsVisible="{Binding HasSelectedSourceFrame}" Stroke="#93C5FD" StrokeThickness="1.2" StrokeShape="RoundRectangle 10" BackgroundColor="#EFF6FF" Padding="12"><VerticalStackLayout Spacing="8"><Grid ColumnDefinitions="*,Auto,Auto"><Label Text="{Binding SelectedSourceFrameNo}" FontSize="16" FontAttributes="Bold" TextColor="#1D4ED8"/><Label Grid.Column="1" Text="待拆分" FontSize="12" TextColor="#2563EB" BackgroundColor="#DBEAFE" Padding="8,2"/><Label Grid.Column="2" Text="✕" FontSize="18" TextColor="#60A5FA"><Label.GestureRecognizers><TapGestureRecognizer Command="{Binding ClearSelectedSourceFrameCommand}"/></Label.GestureRecognizers></Label></Grid><CollectionView ItemsSource="{Binding SelectedSourceMaterials}"><CollectionView.ItemTemplate><DataTemplate><Frame Padding="8" BorderColor="#D1D5DB" CornerRadius="6" HasShadow="False" BackgroundColor="White"><Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto"><Label Text="{Binding MaterialDisplay}" TextColor="#111827"/><Label Grid.Column="1" Grid.RowSpan="2" Text="{Binding QtyDisplay}" FontAttributes="Bold" TextColor="#1F2937" VerticalOptions="Center"/><Label Grid.Row="1" Text="{Binding BatchDisplay}" FontSize="12" TextColor="#6B7280"/></Grid></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView></VerticalStackLayout></Border>
            </VerticalStackLayout>
        </Frame>

        <Frame Grid.Row="1" Margin="0,12,0,0" CornerRadius="12" BackgroundColor="White" BorderColor="#E5E7EB" HasShadow="False" Padding="16">
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"><Label Text="目标拆框（去向）" FontAttributes="Bold" TextColor="#1F2937"/><Button Grid.Column="1" Text="扫码添加" IsEnabled="False" BackgroundColor="#EFF6FF" TextColor="#93C5FD"/><Button Grid.Column="2" Text="列表添加" Command="{Binding OpenTargetPickerCommand}" BackgroundColor="#EFF6FF" TextColor="#2563EB" BorderColor="#BFDBFE" BorderWidth="1"/></Grid>
                <CollectionView ItemsSource="{Binding SelectedTargetFrames}"><CollectionView.EmptyView><Border Stroke="#D1D5DB" StrokeDashArray="6,4" StrokeShape="RoundRectangle 10" HeightRequest="110" BackgroundColor="#F9FAFB"><Label Text="请点击上方按钮添加目标空料框" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#9CA3AF"/></Border></CollectionView.EmptyView><CollectionView.ItemTemplate><DataTemplate><Frame Padding="0" BorderColor="#86EFAC" BackgroundColor="#F0FDF4" CornerRadius="10" HasShadow="False"><VerticalStackLayout Spacing="0"><Grid Padding="10,8" BackgroundColor="#ECFDF5" ColumnDefinitions="Auto,*,Auto"><Frame Padding="0" WidthRequest="22" HeightRequest="22" CornerRadius="11" HasShadow="False" BorderColor="#BBF7D0" BackgroundColor="#DCFCE7"><Label Text="{Binding Index}" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#15803D"/></Frame><Label Grid.Column="1" Margin="10,0,0,0" Text="{Binding TargetFrameNo}" FontSize="16" FontAttributes="Bold" TextColor="#1F2937"/><Label Grid.Column="2" Text="✕" TextColor="#9CA3AF"><Label.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveTargetFrameCommand}" CommandParameter="{Binding .}"/></Label.GestureRecognizers></Label></Grid><Grid Padding="10" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6"><VerticalStackLayout><Label Text="{Binding MaterialName}" TextColor="#111827"/><Label Text="{Binding BatchNo, StringFormat='批号: {0}'}" FontSize="12" TextColor="#6B7280"/></VerticalStackLayout><Entry Grid.Column="1" WidthRequest="110" Text="{Binding UnloadQty}" Placeholder="拆分数量" Keyboard="Numeric"/><Label Grid.Column="2" Text="🗑" VerticalOptions="Center" TextColor="#9CA3AF"><Label.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveTargetFrameCommand}" CommandParameter="{Binding .}"/></Label.GestureRecognizers></Label></Grid></VerticalStackLayout></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView>
            </VerticalStackLayout>
        </Frame>

        <Grid Grid.Row="2"/>
        <Button Grid.Row="3" Margin="0,28,0,24" Text="确认拆框" Command="{Binding ConfirmUnloadCommand}" IsEnabled="{Binding CanConfirmUnload}" BackgroundColor="{Binding ConfirmButtonColor}" TextColor="{Binding ConfirmButtonTextColor}"/>

        <Grid Grid.RowSpan="4" BackgroundColor="#66000000" IsVisible="{Binding IsSourcePickerVisible}"><Frame VerticalOptions="End" CornerRadius="16" BackgroundColor="White" Padding="12"><VerticalStackLayout Spacing="10"><Grid ColumnDefinitions="*,Auto"><Label Text="选择原料框（单选）" FontSize="24" FontAttributes="Bold"/><Button Grid.Column="1" Text="✕" Command="{Binding CloseSourcePickerCommand}"/></Grid><CollectionView ItemsSource="{Binding SourceFrameList}" SelectionMode="Single" SelectedItem="{Binding PickedSourceFrame, Mode=TwoWay}"><CollectionView.ItemTemplate><DataTemplate><Frame Padding="12" Margin="0,6" BorderColor="#D9D9D9" CornerRadius="10" HasShadow="False" BackgroundColor="White"><Frame.Triggers><DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True"><Setter Property="BorderColor" Value="#2F66E8"/><Setter Property="BackgroundColor" Value="#EEF5FF"/></DataTrigger></Frame.Triggers><VerticalStackLayout><Label Text="{Binding frameNo}" FontAttributes="Bold"/><Label Text="{Binding StatusAndCountDisplay}" FontSize="12" TextColor="#6B7280"/></VerticalStackLayout></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView><Button Text="确认选择" Command="{Binding ConfirmPickSourceFrameCommand}" BackgroundColor="#2F66E8" TextColor="White"/></VerticalStackLayout></Frame></Grid>

        <Grid Grid.RowSpan="4" BackgroundColor="#66000000" IsVisible="{Binding IsTargetPickerVisible}"><Frame VerticalOptions="End" CornerRadius="16" BackgroundColor="White" Padding="12"><VerticalStackLayout Spacing="10"><Grid ColumnDefinitions="*,Auto"><Label Text="选择目标拆框（多选）" FontSize="24" FontAttributes="Bold"/><Button Grid.Column="1" Text="✕" Command="{Binding CloseTargetPickerCommand}"/></Grid><CollectionView ItemsSource="{Binding TargetFrameList}"><CollectionView.ItemTemplate><DataTemplate><Frame Padding="12" Margin="0,6" BorderColor="#D9D9D9" CornerRadius="10" HasShadow="False" BackgroundColor="White"><Frame.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleTargetFrameCommand}" CommandParameter="{Binding .}"/></Frame.GestureRecognizers><VerticalStackLayout><Label Text="{Binding frameNo}" FontAttributes="Bold"/><HorizontalStackLayout Spacing="4"><Label Text="状态:" FontSize="12"/><Border Background="#D1FAE5" StrokeThickness="0" Padding="6,2"><Label Text="{Binding frameStatusDisplay}" FontSize="11" TextColor="#059669"/></Border></HorizontalStackLayout></VerticalStackLayout></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView><Button Text="确认选择" Command="{Binding ConfirmPickTargetFramesCommand}" BackgroundColor="#2F66E8" TextColor="White"/></VerticalStackLayout></Frame></Grid>
    </Grid>
</ContentPage>
