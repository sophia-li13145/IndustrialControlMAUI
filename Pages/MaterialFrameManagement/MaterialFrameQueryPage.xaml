<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.MaterialFrameQueryPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="料框查询"
             BackgroundColor="#F4F5F7">

    <Grid RowDefinitions="4*,*" Padding="12,8,12,12" RowSpacing="10">
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Items}"
                        RemainingItemsThreshold="2"
                        RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                        SelectionMode="Single"
                        SelectionChanged="OnItemSelectionChanged">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,10" Padding="12" CornerRadius="12" HasShadow="False" BorderColor="#E5E7EB" BackgroundColor="White">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <Label Text="{Binding FrameNoDisplay}" FontSize="24" FontAttributes="Bold" TextColor="#1F2937"/>
                                <Label Grid.Column="1" Text="{Binding UseStatusText}" Padding="8,2" BackgroundColor="{Binding UseStatusColor}" TextColor="White" FontSize="12"/>
                                <Label Grid.Column="2" Text="{Binding FullLoadStatusText}" Padding="8,2" BackgroundColor="{Binding FullLoadStatusColor}" TextColor="White" FontSize="12"/>
                            </Grid>
                            <Label Text="{Binding CurrentLocationDisplay}" FontSize="14" TextColor="#6B7280"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <Grid Padding="8" HorizontalOptions="Center" IsVisible="{Binding IsLoadingMore}">
                    <ActivityIndicator IsRunning="True"/>
                    <Label Text="加载中..." Margin="8,0,0,0" VerticalOptions="Center"/>
                </Grid>
            </CollectionView.Footer>
            <CollectionView.EmptyView>
                <Label Text="暂无数据"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="#9CA3AF"/>
            </CollectionView.EmptyView>
        </CollectionView>

        <Grid Grid.Row="1" ColumnDefinitions="*,44" ColumnSpacing="8" VerticalOptions="End">
            <Entry x:Name="ScanEntry"
                   Placeholder="输入料框编码查询"
                   Text="{Binding FrameNo}"
                   ReturnType="Search"
                   Completed="OnSearchCompleted"
                   BackgroundColor="White"
                   HeightRequest="40" />
            <ImageButton Grid.Column="1"
                         Source="scan_button.png"
                         BackgroundColor="White"
                         Padding="8"
                         CornerRadius="8"
                         Clicked="OnScanClicked"/>
        </Grid>
    </Grid>
</ContentPage>
