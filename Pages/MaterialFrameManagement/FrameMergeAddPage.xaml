<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.FrameMergeAddPage" xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" Title="新增合框" BackgroundColor="#F4F5F7">
<Grid Padding="12" RowDefinitions="Auto,Auto,*,Auto">
<Frame Padding="12"><VerticalStackLayout><Grid ColumnDefinitions="*,Auto"><Label Text="原料框（来源，可多选）" FontAttributes="Bold"/><Button Grid.Column="1" Text="列表选择" Command="{Binding OpenSourcePickerCommand}"/></Grid><CollectionView ItemsSource="{Binding SelectedSourceFrames}"><CollectionView.ItemTemplate><DataTemplate><Frame Margin="0,4" Padding="8" BorderColor="#BFDBFE" BackgroundColor="#EFF6FF" HasShadow="False"><Label Text="{Binding frameNo}" FontAttributes="Bold"/></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView></VerticalStackLayout></Frame>
<Frame Grid.Row="1" Padding="12" Margin="0,12,0,0"><VerticalStackLayout><Grid ColumnDefinitions="*,Auto"><Label Text="目标合框（去向，空闲）" FontAttributes="Bold"/><Button Grid.Column="1" Text="手动选择" Command="{Binding OpenTargetPickerCommand}"/></Grid><Frame Margin="0,6,0,0" Padding="8" BorderColor="#BBF7D0" BackgroundColor="#F0FDF4" HasShadow="False"><Label Text="{Binding SelectedTargetFrame.frameNo}" FontAttributes="Bold"/></Frame></VerticalStackLayout></Frame>
<Grid Grid.Row="2"/><Button Grid.Row="3" Text="确认合框" Command="{Binding ConfirmCommand}" IsEnabled="{Binding CanConfirm}"/>
<Grid Grid.RowSpan="4" IsVisible="{Binding IsSourcePickerVisible}" BackgroundColor="#66000000"><Frame VerticalOptions="End"><VerticalStackLayout><Label Text="选择原料框（多选）" FontAttributes="Bold"/><CollectionView ItemsSource="{Binding SourceFrameList}" SelectionMode="None"><CollectionView.ItemTemplate><DataTemplate><Frame Margin="0,6" Padding="10" BorderColor="#D9D9D9" HasShadow="False"><Frame.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleSourceCommand}" CommandParameter="{Binding .}"/></Frame.GestureRecognizers><Frame.Triggers><DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True"><Setter Property="BorderColor" Value="#2D73FF"/><Setter Property="BackgroundColor" Value="#EEF5FF"/></DataTrigger></Frame.Triggers><Grid ColumnDefinitions="34,*"><Grid WidthRequest="22" HeightRequest="22" VerticalOptions="Center"><Border Stroke="#C0C4CC" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White"/><Border Stroke="#2D73FF" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#2D73FF" IsVisible="{Binding IsSelected}"/><Label Text="✓" TextColor="White" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsSelected}"/></Grid><Label Grid.Column="1" Text="{Binding frameNo}" FontAttributes="Bold"/></Grid></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView><Button Text="确认选择" Command="{Binding ConfirmSourceCommand}"/></VerticalStackLayout></Frame></Grid>
<Grid Grid.RowSpan="4" IsVisible="{Binding IsTargetPickerVisible}" BackgroundColor="#66000000"><Frame VerticalOptions="End"><VerticalStackLayout><Label Text="选择目标合框（单选）" FontAttributes="Bold"/><CollectionView ItemsSource="{Binding TargetFrameList}" SelectionMode="None"><CollectionView.ItemTemplate><DataTemplate><Frame Margin="0,6" Padding="10" BorderColor="#D9D9D9" HasShadow="False"><Frame.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PickTargetCommand}" CommandParameter="{Binding .}"/></Frame.GestureRecognizers><Frame.Triggers><DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True"><Setter Property="BorderColor" Value="#16A34A"/><Setter Property="BackgroundColor" Value="#F0FDF4"/></DataTrigger></Frame.Triggers><Label Text="{Binding frameNo}" FontAttributes="Bold"/></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView><Button Text="确认选择" Command="{Binding ConfirmTargetCommand}"/></VerticalStackLayout></Frame></Grid>
</Grid></ContentPage>
