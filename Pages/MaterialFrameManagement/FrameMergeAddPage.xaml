<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.FrameMergeAddPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="新增合框"
             BackgroundColor="#F4F5F7">
    <Grid Padding="12" RowDefinitions="Auto,Auto,*,Auto">
        <Frame CornerRadius="12" Padding="14" HasShadow="False" BorderColor="#E5E7EB" BackgroundColor="White">
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Text="原料框（来源，可多选）" FontAttributes="Bold" TextColor="#1F2937"/>
                    <Button Grid.Column="1" Text="扫码添加" Clicked="OnScanSourceClicked" BackgroundColor="#EEF2FF" TextColor="#6366F1"/>
                    <Button Grid.Column="2" Text="列表选择" Command="{Binding OpenSourcePickerCommand}" BackgroundColor="#EEF2FF" TextColor="#6366F1"/>
                </Grid>

                <CollectionView ItemsSource="{Binding SelectedSourceFrames}">
                    <CollectionView.EmptyView>
                        <Border Stroke="#D1D5DB" StrokeDashArray="6,4" StrokeShape="RoundRectangle 10" HeightRequest="110" BackgroundColor="#F9FAFB">
                            <Label Text="请扫码或选择需要合并的原料框" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#9CA3AF"/>
                        </Border>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,4" Padding="10" BorderColor="#BFDBFE" BackgroundColor="#EFF6FF" HasShadow="False" CornerRadius="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding frameNo}" FontAttributes="Bold" TextColor="#1D4ED8"/>
                                    <Label Grid.Column="1" Text="✕" TextColor="#9CA3AF">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveSourceCommand}" CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Frame>

        <Frame Grid.Row="1" Margin="0,12,0,0" CornerRadius="12" Padding="14" HasShadow="False" BorderColor="#E5E7EB" BackgroundColor="White">
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Text="目标合框（去向，空闲）" FontAttributes="Bold" TextColor="#1F2937"/>
                    <Button Grid.Column="1" Text="手动选择" Command="{Binding OpenTargetPickerCommand}" BackgroundColor="#ECFDF5" TextColor="#16A34A"/>
                    <Button Grid.Column="2" Text="扫码目标" Clicked="OnScanTargetClicked" BackgroundColor="#ECFDF5" TextColor="#16A34A"/>
                </Grid>

                <Frame IsVisible="{Binding HasTargetFrame}" Padding="0" BorderColor="#86EFAC" BackgroundColor="#F0FDF4" CornerRadius="10" HasShadow="False">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="10,8" BackgroundColor="#ECFDF5" ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                            <Label Text="{Binding SelectedTargetFrame.frameNo}" FontSize="16" FontAttributes="Bold" TextColor="#1F2937"/>
                            <Label Grid.Column="1" Text="接受合入" TextColor="#16A34A" BackgroundColor="#DCFCE7" Padding="8,2"/>
                            <Label Grid.Column="1" Grid.Row="1" Text="{Binding SelectedTargetFrame.FrameStatusDisplayText, StringFormat=状态: {0}}" TextColor="#15803D" FontSize="12"/>
                            <Label Grid.Column="2" Grid.RowSpan="2" Text="✕" TextColor="#9CA3AF">
                                <Label.GestureRecognizers><TapGestureRecognizer Command="{Binding ClearTargetCommand}"/></Label.GestureRecognizers>
                            </Label>
                        </Grid>
                        <Frame Margin="10" Padding="8" BorderColor="#E5E7EB" BackgroundColor="#FFFFFF" HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Text="合并后物料清单预览" TextColor="#6B7280"/>
                                <Label Grid.Column="1" Grid.RowSpan="2" Text="{Binding TotalQtyDisplay}" FontSize="30" FontAttributes="Bold" TextColor="#4F46E5" VerticalOptions="Center"/>
                                <Label Grid.Row="1" Text="{Binding TotalMaterialNameDisplay}" TextColor="#111827"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </Frame>

        <Grid Grid.Row="2"/>
        <Button Grid.Row="3" Margin="0,24,0,18" Text="确认合框" Command="{Binding ConfirmCommand}" IsEnabled="{Binding CanConfirm}" BackgroundColor="{Binding ConfirmButtonColor}" TextColor="{Binding ConfirmButtonTextColor}"/>

        <Grid Grid.RowSpan="4" IsVisible="{Binding IsSourcePickerVisible}" BackgroundColor="#66000000">
            <Frame VerticalOptions="End" CornerRadius="16" BackgroundColor="White" Padding="12">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="选择原料框（多选）" FontAttributes="Bold"/>
                        <Button Grid.Column="1" Text="✕" Command="{Binding CloseSourcePickerCommand}"/>
                    </Grid>

                    <CollectionView Grid.Row="1" ItemsSource="{Binding SourceFrameList}" SelectionMode="None" HeightRequest="260" RemainingItemsThreshold="1" RemainingItemsThresholdReachedCommand="{Binding LoadMoreSourceFramesCommand}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,6" Padding="12" BorderColor="#D9D9D9" CornerRadius="10" HasShadow="False" BackgroundColor="White">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleSourceCommand}" CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                    <Frame.Triggers>
                                        <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderColor" Value="#2D73FF"/>
                                            <Setter Property="BackgroundColor" Value="#EEF5FF"/>
                                        </DataTrigger>
                                    </Frame.Triggers>
                                    <Grid ColumnDefinitions="34,*" ColumnSpacing="4">
                                        <Grid WidthRequest="22" HeightRequest="22" VerticalOptions="Center">
                                            <Border Stroke="#C0C4CC" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White"/>
                                            <Border Stroke="#2D73FF" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#2D73FF" IsVisible="{Binding IsSelected}"/>
                                            <Label Text="✓" TextColor="White" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsSelected}"/>
                                        </Grid>
                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding frameNo}" FontAttributes="Bold"/>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="状态:" FontSize="12" TextColor="#6B7280"/>
                                                <Border StrokeThickness="0" BackgroundColor="#FEF3C7" Padding="6,1"><Label Text="{Binding FrameStatusDisplayText}" FontSize="11" TextColor="#92400E"/></Border>
                                                <Border StrokeThickness="0" BackgroundColor="#E5E7EB" Padding="6,1"><Label Text="{Binding MaterialTypeCountDisplay}" FontSize="11" TextColor="#4B5563"/></Border>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Grid.Row="2" Text="确认选择" Command="{Binding ConfirmSourceCommand}" BackgroundColor="#2F66E8" TextColor="White" HeightRequest="44"/>
                </Grid>
            </Frame>
        </Grid>

        <Grid Grid.RowSpan="4" IsVisible="{Binding IsTargetPickerVisible}" BackgroundColor="#66000000">
            <Frame VerticalOptions="End" CornerRadius="16" BackgroundColor="White" Padding="12">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" MaximumHeightRequest="420">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="选择目标合框（单选）" FontAttributes="Bold"/>
                        <Button Grid.Column="1" Text="✕" Command="{Binding CloseTargetPickerCommand}"/>
                    </Grid>

                    <CollectionView Grid.Row="1" ItemsSource="{Binding TargetFrameList}" SelectionMode="None" HeightRequest="300" RemainingItemsThreshold="1" RemainingItemsThresholdReachedCommand="{Binding LoadMoreTargetFramesCommand}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,6" Padding="10" BorderColor="#D9D9D9" HasShadow="False">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PickTargetCommand}" CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                    <Frame.Triggers>
                                        <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderColor" Value="#16A34A"/>
                                            <Setter Property="BackgroundColor" Value="#F0FDF4"/>
                                        </DataTrigger>
                                    </Frame.Triggers>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding frameNo}" FontAttributes="Bold"/>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="状态:" FontSize="12" TextColor="#6B7280"/>
                                            <Border Background="#DCFCE7" StrokeThickness="0" Padding="6,2">
                                                <Label Text="{Binding FrameStatusDisplay}" FontSize="11" TextColor="#15803D"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Grid.Row="2" Text="确认选择" Command="{Binding ConfirmTargetCommand}" BackgroundColor="#2F66E8" TextColor="White" HeightRequest="44"/>
                </Grid>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
