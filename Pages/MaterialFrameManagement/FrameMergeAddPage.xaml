<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.FrameMergeAddPage" xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" Title="新增合框" BackgroundColor="#F4F5F7">
<Grid Padding="12" RowDefinitions="Auto,Auto,*,Auto">
<Frame Padding="12"><VerticalStackLayout><Grid ColumnDefinitions="*,Auto"><Label Text="原料框（来源，可多选）" FontAttributes="Bold"/><Button Grid.Column="1" Text="列表选择" Command="{Binding OpenSourcePickerCommand}"/></Grid><CollectionView ItemsSource="{Binding SelectedSourceFrames}"><CollectionView.ItemTemplate><DataTemplate><Label Text="{Binding frameNo}"/></DataTemplate></CollectionView.ItemTemplate></CollectionView></VerticalStackLayout></Frame>
<Frame Grid.Row="1" Padding="12" Margin="0,12,0,0"><VerticalStackLayout><Grid ColumnDefinitions="*,Auto"><Label Text="目标合框（去向，空闲）" FontAttributes="Bold"/><Button Grid.Column="1" Text="手动选择" Command="{Binding OpenTargetPickerCommand}"/></Grid><Label Text="{Binding SelectedTargetFrame.frameNo}"/></VerticalStackLayout></Frame>
<Grid Grid.Row="2"/><Button Grid.Row="3" Text="确认合框" Command="{Binding ConfirmCommand}" IsEnabled="{Binding CanConfirm}"/>
<Grid Grid.RowSpan="4" IsVisible="{Binding IsSourcePickerVisible}" BackgroundColor="#66000000"><Frame VerticalOptions="End"><VerticalStackLayout><Label Text="选择原料框（多选）" FontAttributes="Bold"/><CollectionView ItemsSource="{Binding SourceFrameList}"><CollectionView.ItemTemplate><DataTemplate><Frame><Frame.GestureRecognizers><TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleSourceCommand}" CommandParameter="{Binding .}"/></Frame.GestureRecognizers><Label Text="{Binding frameNo}"/></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView><Button Text="确认选择" Command="{Binding ConfirmSourceCommand}"/></VerticalStackLayout></Frame></Grid>
<Grid Grid.RowSpan="4" IsVisible="{Binding IsTargetPickerVisible}" BackgroundColor="#66000000"><Frame VerticalOptions="End"><VerticalStackLayout><Label Text="选择目标合框（单选）" FontAttributes="Bold"/><CollectionView ItemsSource="{Binding TargetFrameList}" SelectionMode="Single" SelectedItem="{Binding SelectedTargetFrame}"><CollectionView.ItemTemplate><DataTemplate><Frame><Label Text="{Binding frameNo}"/></Frame></DataTemplate></CollectionView.ItemTemplate></CollectionView><Button Text="确认选择" Command="{Binding ConfirmTargetCommand}"/></VerticalStackLayout></Frame></Grid>
</Grid></ContentPage>
