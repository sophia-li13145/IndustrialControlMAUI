<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="IndustrialControlMAUI.Pages.FrameLoadAddPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="新增装框"
             BackgroundColor="#F4F5F7">
    <Grid Padding="12" RowDefinitions="Auto,Auto,*,Auto">
        <Frame CornerRadius="12"
       BackgroundColor="White"
       BorderColor="#E5E7EB"
       HasShadow="False"
       Padding="16">

            <VerticalStackLayout Spacing="12">

                <HorizontalStackLayout Spacing="6">
                    <Label Text="▱"
                   FontSize="16"
                   TextColor="#2D73FF"
                   VerticalOptions="Center"/>
                    <Label Text="装载物料"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#1F2937"
                   VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Grid ColumnDefinitions="*,*"
              ColumnSpacing="12">

                    <!-- 下拉选择 -->
                    <Border HeightRequest="84"
                    Stroke="#CBD5E1"
                    StrokeThickness="1.5"
                    StrokeDashArray="6,4"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="#FAFCFF">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenPickerCommand}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="6">
                            <Label Text="☰"
                           Rotation="90"
                           FontSize="22"
                           TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                            <Label Text="下拉选择"
                           FontSize="14"
                           TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- 扫码输入 -->
                    <Border Grid.Column="1"
                    HeightRequest="84"
                    Stroke="#93C5FD"
                    StrokeThickness="1.5"
                    StrokeDashArray="6,4"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="#EFF6FF">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnScanClicked" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="6">
                            <Label Text="⌗"
                           FontSize="26"
                           TextColor="#2D73FF"
                           HorizontalOptions="Center"/>
                            <Label Text="扫码输入"
                           FontSize="14"
                           TextColor="#2D73FF"
                           HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </VerticalStackLayout>
        </Frame>

        <Frame Grid.Row="1" Margin="0,12,0,0" CornerRadius="12" BackgroundColor="White" BorderColor="#E5E7EB" HasShadow="False">
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Label Text="分配至目标料框（空闲）" FontAttributes="Bold" TextColor="#1F2937"/>
                    <Button Grid.Column="1" Text="扫码添加" BackgroundColor="#EFF6FF" TextColor="#2563EB" BorderColor="#BFDBFE" BorderWidth="1"/>
                    <Button Grid.Column="2" Text="列表添加" Command="{Binding OpenTargetFramePopupCommand}" BackgroundColor="#EFF6FF" TextColor="#2563EB" BorderColor="#BFDBFE" BorderWidth="1"/>
                </Grid>
                <CollectionView ItemsSource="{Binding SelectedTargetFrames}" HeightRequest="240">
                    <CollectionView.EmptyView>
                        <Label Text="请点击上方按钮添加目标空闲料框" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#9CA3AF"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="0" BorderColor="#BBF7D0" BackgroundColor="#F0FDF4" CornerRadius="10" HasShadow="False">
                                <VerticalStackLayout Spacing="0">
                                    <Grid Padding="10,8" ColumnDefinitions="Auto,*,Auto">
                                        <Frame Grid.Column="0" Padding="0" WidthRequest="20" HeightRequest="20" CornerRadius="10" BackgroundColor="#BBF7D0" HasShadow="False" BorderColor="#BBF7D0">
                                            <Label Text="{Binding Index}" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#15803D"/>
                                        </Frame>
                                        <Label Grid.Column="1" Margin="10,0,0,0" Text="{Binding FrameNo}" FontAttributes="Bold" TextColor="#1F2937"/>
                                        <Label Grid.Column="2" Text="✕" TextColor="#9CA3AF">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveTargetFrameCommand}" CommandParameter="{Binding .}"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                    <Grid Padding="10" BackgroundColor="#F8FAFC" ColumnDefinitions="Auto,*">
                                        <Label Text="装入数量" VerticalOptions="Center"/>
                                        <Entry Grid.Column="1" Text="{Binding Qty}" Placeholder="请输入分配数量" BackgroundColor="White"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Frame>

        <Grid Grid.Row="2"/>

        <Button Grid.Row="3"
                Margin="0,28,0,24"
                Text="确认装框"
                Command="{Binding ConfirmLoadCommand}"
                IsEnabled="{Binding CanConfirmLoad}"
                BackgroundColor="{Binding ConfirmButtonColor}"
                TextColor="{Binding ConfirmButtonTextColor}"/>

        <Grid x:Name="PickerOverlay" Grid.RowSpan="4" BackgroundColor="#66000000" IsVisible="{Binding IsPickerVisible}">
            <Frame VerticalOptions="End" CornerRadius="16" BackgroundColor="White" Padding="12" Margin="0,0,0,0">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="选择物料" FontSize="24" FontAttributes="Bold"/>
                        <Button Grid.Column="1" Text="✕" Command="{Binding ClosePickerCommand}"/>
                    </Grid>
                    <SearchBar Placeholder="输入物料名模糊查询" Text="{Binding MaterialNameKeyword}" SearchCommand="{Binding SearchMaterialsCommand}"/>
                    <CollectionView ItemsSource="{Binding MaterialList}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="12" BorderColor="#E5E7EB" CornerRadius="10" HasShadow="False">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PickMaterialCommand}"
                                                              CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding materialName}" FontAttributes="Bold"/>
                                        <Label Grid.Column="1" Text="{Binding materialCode}" TextColor="#94A3B8"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <Grid Grid.RowSpan="4" BackgroundColor="#66000000" IsVisible="{Binding IsTargetFramePopupVisible}">
            <Frame VerticalOptions="End" CornerRadius="16" BackgroundColor="White" Padding="12">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="选择目标料框（空闲, 多选）" FontSize="24" FontAttributes="Bold"/>
                        <Button Grid.Column="1" Text="✕" Command="{Binding CloseTargetFramePopupCommand}"/>
                    </Grid>
                    <CollectionView ItemsSource="{Binding TargetFrameList}"
                SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <Frame Padding="12"
                   Margin="0,6"
                   CornerRadius="10"
                   BorderColor="#D9D9D9"
                   HasShadow="False"
                   BackgroundColor="White">

                                    <!-- 点击事件移到 Frame -->
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                          Path=BindingContext.ToggleTargetFrameCommand}"
                        CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>

                                    <!-- 选中样式 -->
                                    <Frame.Triggers>
                                        <DataTrigger TargetType="Frame"
                                 Binding="{Binding IsSelected}"
                                 Value="True">

                                            <Setter Property="BorderColor"
                                Value="#2D73FF"/>

                                            <Setter Property="BackgroundColor"
                                Value="#EEF5FF"/>
                                        </DataTrigger>
                                    </Frame.Triggers>

                                    <Grid ColumnDefinitions="40,*">

                                        <!-- 左侧复选框 -->
                                        <Grid WidthRequest="24"
                          HeightRequest="24"
                          VerticalOptions="Center">

                                            <Border Stroke="#C0C4CC"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="White"/>

                                            <!-- 选中状态 -->
                                            <Border Stroke="#2D73FF"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#2D73FF"
                                IsVisible="{Binding IsSelected}"/>

                                            <Label Text="✓"
                               TextColor="White"
                               FontSize="12"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               IsVisible="{Binding IsSelected}"/>

                                        </Grid>

                                        <!-- 内容 -->
                                        <VerticalStackLayout Grid.Column="1"
                                         Spacing="4">

                                            <Label Text="{Binding frameNo}"
                               FontSize="18"
                               FontAttributes="Bold"/>

                                            <HorizontalStackLayout Spacing="4">

                                                <Label Text="状态:"
                                   FontSize="12"/>

                                                <Border Background="#D8F5E2"
                                    StrokeThickness="0"
                                    Padding="6,2">

                                                    <Label Text="{Binding frameStatus}"
                                       FontSize="11"
                                       TextColor="#2FA84F"/>

                                                </Border>

                                            </HorizontalStackLayout>

                                        </VerticalStackLayout>

                                    </Grid>

                                </Frame>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>
                    <Button Text="{Binding SelectedTargetFrameCount, StringFormat='确认选择 ({0})'}" Command="{Binding CloseTargetFramePopupCommand}" BackgroundColor="#2F66E8" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
