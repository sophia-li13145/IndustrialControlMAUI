<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="IndustrialControlMAUI.Popups.InspectionDataPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:IndustrialControlMAUI.ViewModels"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
    x:DataType="vm:InspectionDataPopupViewModel"
    CanBeDismissedByTappingOutsideOfPopup="False">

    <Border
        WidthRequest="760"
        HeightRequest="620"
        Padding="12"
        BackgroundColor="White"
        Stroke="#D9E2F1"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 12">

        <Grid RowDefinitions="Auto,280,Auto,*,Auto"
              RowSpacing="10">

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <Label Text="检验详细数据"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#1F2937"
                       VerticalOptions="Center" />

                <Button Grid.Column="1"
                        Text="关闭"
                        Clicked="OnCloseClicked"
                        BackgroundColor="#E5E7EB"
                        TextColor="#111827"
                        CornerRadius="8"
                        Padding="16,8"
                        FontSize="14"/>
            </Grid>

            <Border Grid.Row="1"
                    Padding="8"
                    BackgroundColor="#FAFAFA"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10">

                <Grid>
                    <lvc:CartesianChart
                        Series="{Binding Series}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}" />

                    <Label Text="暂无图表数据"
                           IsVisible="{Binding NoChartDataVisible}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="#9CA3AF"
                           FontSize="15"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  ColumnDefinitions="60,2*,*,2*"
                  Padding="8,8"
                  BackgroundColor="#F3F4F6">
                <Label Text="序号" FontAttributes="Bold" TextColor="#111827" />
                <Label Grid.Column="1" Text="采集参数" FontAttributes="Bold" TextColor="#111827" />
                <Label Grid.Column="2" Text="数值" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="#111827" />
                <Label Grid.Column="3" Text="采集时间" FontAttributes="Bold" HorizontalTextAlignment="End" TextColor="#111827" />
            </Grid>

            <CollectionView Grid.Row="3"
                            ItemsSource="{Binding Rows}"
                            SelectionMode="None"
                            VerticalOptions="FillAndExpand">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:InspectionDataRow">
                        <Grid ColumnDefinitions="60,2*,*,2*"
                              Padding="8,10">
                            <Label Text="{Binding RowNo}" TextColor="#374151" />
                            <Label Grid.Column="1"
                                   Text="{Binding ParamName}"
                                   TextColor="#374151"
                                   LineBreakMode="TailTruncation"/>
                            <Label Grid.Column="2"
                                   Text="{Binding Value}"
                                   TextColor="#374151"
                                   HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="3"
                                   Text="{Binding CollectTime}"
                                   TextColor="#374151"
                                   HorizontalTextAlignment="End"
                                   LineBreakMode="TailTruncation"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Button Text="上一页"
                        Command="{Binding PrevCommand}"
                        BackgroundColor="#E5E7EB"
                        TextColor="#111827"
                        CornerRadius="8"
                        Padding="18,8"
                        FontSize="14"/>

                <Label Grid.Column="1"
                       Text="{Binding PageInfo}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="#4B5563"
                       FontSize="14"/>

                <Button Grid.Column="2"
                        Text="下一页"
                        Command="{Binding NextCommand}"
                        BackgroundColor="#3B82F6"
                        TextColor="White"
                        CornerRadius="8"
                        Padding="18,8"
                        FontSize="14"/>
            </Grid>
        </Grid>
    </Border>
</toolkit:Popup>