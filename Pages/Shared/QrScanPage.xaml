<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    x:Class="IndustrialControlMAUI.Pages.QrScanPage"
    Title="扫码">

    <Grid RowDefinitions="*,Auto">
        <!-- 扫码取码：模拟器摄像头清晰度较低，预览区域必须尽量大，否则很难识别二维码。 -->
        <zxing:CameraBarcodeReaderView
            x:Name="barcodeView"
            Grid.Row="0"
            BarcodesDetected="BarcodesDetected"
            IsDetecting="False" />

        <!-- 显示扫码结果/提示，覆盖在预览区域底部，避免压缩摄像头画面。 -->
        <Label x:Name="ResultLabel"
               Grid.Row="0"
               Text="请对准二维码..."
               FontSize="18"
               TextColor="White"
               BackgroundColor="#99000000"
               Padding="12,8"
               Margin="16"
               HorizontalOptions="Center"
               VerticalOptions="End" />

        <!-- 底部按钮区 -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,Auto,*,Auto"
              Padding="20"
              BackgroundColor="#222">
            <!-- 新增：相册识别 -->
            <Button Text="相册识别"
                    Grid.Column="0"
                    Clicked="PickFromGalleryButton_Clicked" />
            
            <Button Text="🔄"
                    Grid.Column="1"
                    BackgroundColor="#444"
                    BorderColor="Black"
                    Clicked="SwitchCameraButton_Clicked" />

            <zxing:BarcodeGeneratorView
                x:Name="barcodeGenerator"
                Grid.Column="2"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                HeightRequest="100"
                WidthRequest="100"
                ForegroundColor="DarkBlue"
                Format="QrCode"
                Value="Sample"
                BarcodeMargin="1" />

            <Button Text="💡"
                    Grid.Column="3"
                    BackgroundColor="#444"
                    BorderColor="Black"
                    Clicked="TorchButton_Clicked" />
        </Grid>
    </Grid>
</ContentPage>
